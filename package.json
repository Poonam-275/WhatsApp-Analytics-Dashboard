{
  "name": "whatsapp-analytics-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["backend", "frontend", "shared"],
  "scripts": {
    "build": "npm run -w shared build && npm run -w backend build && npm run -w frontend build",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev --workspace backend\" \"npm:dev --workspace frontend\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.base.json --noEmit"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "concurrently": "^9.0.1",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
